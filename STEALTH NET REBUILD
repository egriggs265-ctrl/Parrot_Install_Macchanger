sudo bash -c 'cat > /root/stealth_net_rebuild.sh <<'"'"'EOF'"'"'
#!/usr/bin/env bash
#
# ============================================================
#  STEALTH NET REBUILD
#  Safe to keep comments/header at the top.
#  Re-runnable recovery script for Parrot/BlackArch-style setups.
# ============================================================

set -u

echo "[*] STEALTH NET REBUILD START"

need_cmd() {
  command -v "$1" >/dev/null 2>&1
}

log() {
  echo "[*] $1"
}

warn() {
  echo "[!] $1"
}

MISSING=0
for cmd in ip awk grep macchanger; do
  if ! need_cmd "$cmd"; then
    warn "Missing required command: $cmd"
    MISSING=1
  fi
done

if [ "$MISSING" -ne 0 ]; then
  warn "Install missing tools first, then rerun."
  exit 1
fi

if [ "$(id -u)" -ne 0 ]; then
  warn "Run this script as root."
  exit 1
fi

IFACE="$(ip -br link | awk '"'"'$1 ~ /^wl/ {print $1; exit}'"'"')"

if [ -z "${IFACE:-}" ]; then
  warn "No wireless interface found."
  ip -br link
  exit 1
fi

log "Detected interface: $IFACE"

if echo "$IFACE" | grep -q "mon$"; then
  BASE_IFACE="${IFACE%mon}"
  log "Monitor mode detected on $IFACE"

  if need_cmd airmon-ng; then
    log "Stopping monitor mode with airmon-ng"
    airmon-ng stop "$IFACE" 2>/dev/null || true
  fi

  ip link set "$IFACE" down 2>/dev/null || true

  if need_cmd iw; then
    iw dev "$IFACE" del 2>/dev/null || true
  fi

  IFACE="$BASE_IFACE"
  log "Recovered base interface: $IFACE"
fi

if ! ip link show "$IFACE" >/dev/null 2>&1; then
  if need_cmd iw; then
    IFACE="$(iw dev 2>/dev/null | awk '"'"'$1=="Interface"{print $2; exit}'"'"')"
  fi
fi

if [ -z "${IFACE:-}" ] || ! ip link show "$IFACE" >/dev/null 2>&1; then
  warn "Could not recover a managed wireless interface."
  if need_cmd iw; then
    iw dev 2>/dev/null || true
  fi
  ip -br link
  exit 1
fi

log "Using interface: $IFACE"

echo
echo "[*] BEFORE:"
macchanger -s "$IFACE" 2>/dev/null || ip link show "$IFACE"

echo
log "Stopping conflicting services"
systemctl stop NetworkManager 2>/dev/null || true
killall wpa_supplicant dhclient 2>/dev/null || true

log "Bringing interface down"
ip link set "$IFACE" down 2>/dev/null || true

if need_cmd iw; then
  log "Setting managed mode with iw"
  iw dev "$IFACE" set type managed 2>/dev/null || true
elif need_cmd iwconfig; then
  log "Setting managed mode with iwconfig"
  iwconfig "$IFACE" mode managed 2>/dev/null || true
else
  warn "No iw/iwconfig found; skipping mode set"
fi

log "Randomizing MAC"
if ! macchanger -r "$IFACE"; then
  warn "MAC change failed"
  exit 1
fi

log "Bringing interface up"
ip link set "$IFACE" up 2>/dev/null || true

log "Restarting NetworkManager"
systemctl start NetworkManager 2>/dev/null || true
systemctl restart NetworkManager 2>/dev/null || true

sleep 3

if need_cmd nmcli; then
  log "Triggering reconnect with nmcli"
  nmcli radio wifi on 2>/dev/null || true
  nmcli device set "$IFACE" managed yes 2>/dev/null || true
  nmcli device connect "$IFACE" 2>/dev/null || true
fi

if need_cmd dhclient; then
  log "Requesting DHCP lease"
  dhclient -v "$IFACE" 2>/dev/null || true
fi

sleep 5

echo
echo "[*] AFTER:"
macchanger -s "$IFACE" 2>/dev/null || ip link show "$IFACE"

echo
echo "[*] LINK STATUS:"
ip -br addr show "$IFACE"

echo
if need_cmd nmcli; then
  echo "[*] NMCLI STATUS:"
  nmcli device status 2>/dev/null || true
  echo
fi

echo "[✓] STEALTH NET REBUILD COMPLETE"
EOF
chmod +x /root/stealth_net_rebuild.sh
echo
echo "[*] Saved: /root/stealth_net_rebuild.sh"
echo "[*] Executing now..."
/root/stealth_net_rebuild.sh'
